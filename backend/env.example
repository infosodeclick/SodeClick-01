# Development Environment
PORT=5000
MONGODB_URI=mongodb+srv://<db-user>:<db-password>@<cluster>/<db-name>?retryWrites=true&w=majority
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# JWT Secret
JWT_SECRET=replace-with-strong-random-secret

# SMS Service (Optional - for phone verification)
SMS_API_KEY=your-sms-api-key
SMS_API_SECRET=your-sms-api-secret

# Email Service Configuration (Nodemailer - Fallback)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com

# Resend API Configuration (Primary email service - uses API instead of SMTP)
# Get your API key from https://resend.com
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Cloudinary Configuration (Image Upload & CDN)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_URL=cloudinary://<api-key>:<api-secret>@<cloud-name>

# Rabbit Payment Gateway Configuration
RABBIT_API_URL=https://api.pgw.rabbit.co.th
RABBIT_APPLICATION_ID=your-rabbit-application-id
RABBIT_PUBLIC_KEY=your-rabbit-public-key
RABBIT_COMPANY_ID=your-rabbit-company-id
RABBIT_API_KEY=your-rabbit-api-key
